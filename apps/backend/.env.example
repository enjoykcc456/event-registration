# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=event_registration
DB_USER=root
DB_PASSWORD=password

# OneMap API (register at https://www.onemap.gov.sg/apidocs/register)
ONEMAP_EMAIL=your-email@example.com
ONEMAP_PASSWORD=your-onemap-password

# Server
PORT=8000

# CORS
FRONTEND_ORIGIN=http://localhost:8001
